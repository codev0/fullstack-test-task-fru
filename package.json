  "dependencies": {
    "@fastify/autoload": "^6.3.0",
    "@fastify/env": "^5.0.2",
    "@fastify/sensible": "^6.0.3",
    "@fastify/static": "^8.1.1",
    "fastify": "^5.3.3",
    "fastify-cli": "^7.4.0",
    "fastify-plugin": "^5.0.1"
  },
  "engines": {
    "node": ">=22.15.0"
  },
  "private": true,
  "devDependencies": {
    "@types/node": "^22.15.18",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.4",
    "fastify-tsconfig": "^3.0.0",
    "serve": "^14.2.4",
    "typescript": "^5.8.3"
  }
}
